[
{"id":1,"t":"Dryer Exhaust Duct Material","c":"IMC 504.6","s":"FAIL","why":"Screws, foil tape, or plastic used.","fix":"Rigid metal duct. UL181B-FX tape only. No screws inside.","rep":"IMC 504.6 requires smooth interior rigid metal duct."},
{"id":2,"t":"Dryer Vent Length Max","c":"IMC 504.6.4.1","s":"CHECK","why":"Run exceeds 35ft before deductions.","fix":"45° elbow = -2.5ft. 90° = -5ft. Max 35ft minus all fittings.","rep":"Per Table 504.6.4.1 we must deduct for each elbow."},
{"id":3,"t":"Dryer Termination Screen","c":"IMC 504.6.3","s":"FAIL","why":"Screen or trap at termination.","fix":"Remove screen. Use listed backdraft damper only.","rep":"IMC 504.6.3 prohibits screens that can clog."},
{"id":4,"t":"Bath Fan Termination","c":"IMC 504.4","s":"FAIL","why":"Terminates in attic, soffit, or crawl.","fix":"Terminate outside through roof or wall cap.","rep":"IMC 504.4 requires termination to the outdoors."},
{"id":5,"t":"Bath Fan Duct Size","c":"IMC 504.6","s":"CHECK","why":"4in duct on 150+ CFM fan.","fix":"Upsize to 6in for 150+ CFM. Keep run short.","rep":"Undersized duct causes back pressure and noise."},
{"id":6,"t":"Kitchen Hood CFM >400","c":"IMC 507.2","s":"FAIL","why":"Hood >400 CFM with no MUA.","fix":"Add MUA interlocked or downsize hood <400 CFM.","rep":"IMC 507.2 requires MUA for exhaust >400 CFM."},
{"id":7,"t":"Hood Duct Material","c":"IMC 506.3","s":"FAIL","why":"B-Vent or flex duct on grease hood.","fix":"16ga black steel, welded seams, 18in to hood.","rep":"IMC 506.3.1 requires grease duct of steel."},
{"id":8,"t":"Hood Cleanout Access","c":"IMC 506.3.10","s":"CHECK","why":"No access panel within 20ft.","fix":"Install listed access panel at 20ft max intervals.","rep":"IMC 506.3.10 requires access for cleaning."},
{"id":9,"t":"Hood to Combustible","c":"IMC 506.3.6","s":"FAIL","why":"<18in clearance to wood.","fix":"Add 18in or UL 1978 duct with 0 clearance.","rep":"IMC 506.3.6 requires 18in to combustibles."},
{"id":10,"t":"Furnace Service Clearance","c":"IMC 306.5","s":"CHECK","why":"<30in x 30in working space.","fix":"Clear 30in deep x 30in wide in front of unit.","rep":"IMC 306.5 mandates 30in service clearance."},
{"id":11,"t":"Water Heater Vent Material","c":"IMC 802","s":"FAIL","why":"Single wall on B-Vent appliance.","fix":"Use Type B vent or listed single wall with clearance.","rep":"IMC 802 requires listed vent per appliance listing."},
{"id":12,"t":"Vent Clearance Combustible","c":"IMC 802.6","s":"FAIL","why":"Single wall <6in to wood.","fix":"6in clearance or switch to B-Vent 1in.","rep":"IMC Table 802.6.1 requires 6in for single wall."},
{"id":13,"t":"Vent Slope","c":"IMC 802.10","s":"CHECK","why":"Vent slopes down or flat.","fix":"1/4in per ft rise back to appliance.","rep":"IMC 802.10 requires positive slope to drain condensate."},
{"id":14,"t":"Vent Support","c":"IMC 802.8","s":"CHECK","why">5ft between supports.","fix":"Support every 5ft vertical, 4ft horizontal.","rep":"IMC 802.8 requires proper support of vents."},
{"id":15,"t":"Vent Termination Height","c":"IMC 802.7","s":"CHECK","why":"<2ft above roof or near window.","fix":"2ft above roof within 10ft. 4ft from opening.","rep":"IMC 802.7.1 gives termination height rules."},
{"id":16,"t":"Combustion Air Closet","c":"IMC 701.4","s":"FAIL","why":"Closet install with no openings.","fix":"2 openings: 1in² per 1000 BTU each, high+low.","rep":"IMC 701.4.1 requires two permanent openings."},
{"id":17,"t":"Combustion Air Duct Size","c":"IMC 701.4.1","s":"CHECK","why":"1 duct for >100k BTU.","fix":"Two ducts or 1ft² per 4000 BTU direct.","rep":"IMC 701.4.1 sizing for indoor air method."},
{"id":18,"t":"Direct Vent Sealed","c":"IMC 701.2","s":"PASS","why":"Sealed combustion unit.","fix":"None. Follow manufacturer. No room air.","rep":"Direct vent uses outdoor air per IMC 701.2."},
{"id":19,"t":"Attic Condensate Pan","c":"IMC 307.2.3","s":"FAIL","why":"No secondary pan under AHU.","fix":"3in deep pan, 1.5in larger than unit.","rep":"IMC 307.2.3 requires secondary pan in attics."},
{"id":20,"t":"Pan Drain Termination","c":"IMC 307.2.3","s":"FAIL","why":"Pan drains to hidden location.","fix":"Drain to conspicuous location outside.","rep":"IMC 307.2.3 requires conspicuous termination."},
{"id":21,"t":"Condensate Trap","c":"IMC 307.2.2","s":"FAIL","why":"No P-trap on negative pressure.","fix":"Install trap per mfg depth. Prime it.","rep":"IMC 307.2.2 requires trap to prevent air lock."},
{"id":22,"t":"Condensate Line Pitch","c":"IMC 307.2","s":"CHECK","why":"Flat or uphill drain.","fix":"1/8in per ft minimum slope.","rep":"IMC 307.2 requires gravity flow to drain."},
{"id":23,"t":"Aux Drain Shutoff","c":"IMC 307.2.3","s":"FAIL","why":"No float switch on secondary.","fix":"Install float switch to kill unit.","rep":"IMC 307.2.3 requires shutoff to prevent damage."},
{"id":24,"t":"Duct Sealing Mastic","c":"IMC 603.9","s":"FAIL","why":"Cloth duct tape on seams.","fix":"UL181B-FX tape or UL181 mastic only.","rep":"IMC 603.9 prohibits cloth duct tape."},
{"id":25,"t":"Flex Duct Sag","c":"IMC 603.4","s":"CHECK","why":"Flex sag >1/2in per ft.","fix":"Support every 4ft. Full extension, no kinks.","rep":"IMC 603.4 limits sag to prevent restriction."},
{"id":26,"t":"Flex Duct Bends","c":"IMC 603.4","s":"CHECK","why":"Tight 90° bends.","fix":"Use elbows. Max 1 bend per 15ft.","rep":"Sharp bends kill airflow per IMC 603.4."},
{"id":27,"t":"Duct R-Value Attic","c":"IECC C403.11","s":"CHECK","why":"<R-8 in unconditioned space.","fix":"Wrap to R-8 minimum. Seal first.","rep":"IECC C403.11.3 requires R-8 in attics."},
{"id":28,"t":"Duct R-Value Crawl","c":"IECC C403.11","s":"CHECK","why":"<R-6 in crawlspace.","fix":"Wrap to R-6 minimum.","rep":"IECC C403.11.3 requires R-6 in crawl."},
{"id":29,"t":"Duct Leakage Test","c":"IECC C403.12","s":"CHECK","why":"No test on new system.","fix":"Test to <4 CFM25 per 100ft².","rep":"IECC C403.12.3 requires duct leakage test."},
{"id":30,"t":"Return Air Path","c":"IMC 601.3","s":"FAIL","why":"Panned joist return no duct.","fix":"Install metal duct or sealed ductboard.","rep":"IMC 601.3 prohibits stud/joist cavities."},
{"id":31,"t":"Filter Access","c":"IMC 605.1","s":"CHECK","why":"No access to filter.","fix":"Install access door at filter.","rep":"IMC 605.1 requires access for service."},
{"id":32,"t":"Equipment Access Platform","c":"IMC 306.3","s":"FAIL","why":"No platform or walkway to attic unit.","fix":"30in x 30in platform + walkway.","rep":"IMC 306.3 requires access for service."},
{"id":33,"t":"Attic Light + Outlet","c":"IMC 306.5","s":"FAIL","why":"No light or 120V at unit.","fix":"Add switched light + outlet within 25ft.","rep":"IMC 306.5 requires light and receptacle."},
{"id":34,"t":"Gas Shutoff Access","c":"IFGC 409","s":"FAIL","why":"Shutoff behind panel or unit.","fix":"Accessible shutoff within 6ft.","rep":"IFGC 409.1 requires accessible valve."},
{"id":35,"t":"Gas Drip Leg","c":"IFGC 408","s":"FAIL","why":"No sediment trap.","fix":"Install drip leg before appliance.","rep":"IFGC 408.4 requires sediment trap."},
{"id":36,"t":"Gas Pipe Support","c":"IFGC 415","s":"CHECK","why">6ft between supports.","fix":"Support every 6ft or per code.","rep":"IFGC 415 requires proper support."},
{"id":37,"t":"Electrical Disconnect","c":"IMC 306.4","s":"FAIL","why">">">50ft or not in sight.","fix":"Disconnect within sight, <50ft.","rep":"IMC 306.4 requires disconnect at unit."},
{"id":38,"t":"Label Clearances","c":"IMC 306.5","s":"CHECK","why":"Labels blocked by piping.","fix":"Keep data plate visible.","rep":"IMC 306.5 requires access to nameplate."},
{"id":39,"t":"Refrigerant Line Protection","c":"IMC 1108","s":"CHECK","why":"Unprotected lineset outdoors.","fix":"Add line set cover or chase.","rep":"IMC 1108 requires protection from damage."},
{"id":40,"t":"Condenser Clearance","c":"IMC 306.5","s":"CHECK","why":"<12in from wall.","fix":"12in minimum service clearance.","rep":"Mfg + IMC require service space."},
{"id":41,"t":"Condenser on Ground","c":"IMC 306.5","s":"CHECK","why":"Unit sits in dirt/water.","fix":"Pad or stand 3in minimum.","rep":"Prevent flood and debris per mfg."},
{"id":42,"t":"Thermostat Location","c":"IECC R403.8","s":"CHECK","why":"Stat in sun or near supply.","fix":"Interior wall, away from drafts/sun.","rep":"IECC requires representative sensing."},
{"id":43,"t":"Makeup Air Interlock","c":"IMC 507.2","s":"FAIL","why":"MUA fan not interlocked.","fix":"Wire MUA to run with hood.","rep":"IMC 507.2 requires simultaneous operation."},
{"id":44,"t":"Hood Velocity","c":"IMC 507.4","s":"CHECK","why"<100 FPM at face.","fix":"Adjust fan or resize hood.","rep":"IMC 507.4 requires 100-200 FPM."},
{"id":45,"t":"Grease Duct Slope","c":"IMC 506.3.7","s":"FAIL","why":"Flat grease duct.","fix":"1/4in per ft back to hood.","rep":"IMC 506.3.7 requires slope to drain."},
{"id":46,"t":"Fire Suppression","c":"IMC 507.3","s":"FAIL","why">">">Commercial hood no Ansul.","fix":"Install listed suppression system.","rep":"IMC 507.3 requires suppression for cooking."},
{"id":47,"t":"Bath Fan CFM","c":"IMC 403","s":"CHECK","why"<50 CFM intermittent.","fix":"50 CFM min intermittent, 20 cont.","rep":"IMC Table 403.3.1.1 minimums."},
{"id":48,"t":"Bath Fan Timer","c":"IMC 403","s":"CHECK","why">20min no auto off.","fix":"Add timer or humidity switch.","rep":"IMC 403 requires adequate runtime."},
{"id":49,"t":"Exhaust Termination Height","c":"IMC 501.3","s":"CHECK","why"<3ft from opening.","fix":"3ft from openings, 10ft from mech intake.","rep":"IMC 501.3 separation distances."},
{"id":50,"t":"Exhaust to Garage","c":"IMC 501.2","s":"FAIL","why":"Bath/dryer vents to garage.","fix":"Reroute to exterior.","rep":"IMC 501.2 prohibits termination in garage."},
{"id":51,"t":"Furnace Flue Liner","c":"IMC 802","s":"FAIL","why":"Oversized masonry flue.","fix":"Line to appliance size.","rep":"IMC 802.26 requires proper flue size."},
{"id":52,"t":"CO Detector","c":"IRC R315","s":"FAIL","why":"Fuel appliance no CO alarm.","fix":"Install CO detector per IRC.","rep":"IRC R315 requires CO alarms."},
{"id":53,"t":"Return Air Filter Size","c":"IMC 605","s":"CHECK","why">">">500 FPM face velocity.","fix":"Increase filter area.","rep":"Keep velocity <500 FPM."},
{"id":54,"t":"Duct Support Spacing","c":"IMC 603.10","s":"CHECK","why">4ft between hangers.","fix":"Support every 4ft metal, 3ft flex.","rep":"IMC 603.10 support requirements."},
{"id":55,"t":"Duct Penetration Fire","c":"IMC 607","s":"FAIL","why":"No damper through fire wall.","fix":"Install listed fire damper.","rep":"IMC 607 requires dampers in rated assemblies."},
{"id":56,"t":"Fresh Air Ventilation","c":"IMC 403","s":"CHECK","why">No OA on new build.","fix":"Add ERV/HRV or OA damper.","rep":"IMC 403.3 requires ventilation air."},
{"id":57,"t":"ERU/HRV Drain","c":"IMC 307","s":"CHECK","why">">No condensate drain.","fix":"Trap + drain to plumbing.","rep":"IMC 307 applies to ERV condensate."},
{"id":58,"t":"Water Heater T&P Drain","c":"IPC 504","s":"FAIL","why">No T&P drain line.","fix":"Full size to 6in of floor.","rep":"IPC 504.6 requires T&P discharge."},
{"id":59,"t":"Water Heater Pan","c":"IPC 504","s":"FAIL","why">No pan in attic/interior.","fix":"Add pan with drain.","rep":"IPC 504.7 requires pan in sensitive locations."},
{"id":60,"t":"Seismic Strapping","c":"IPC 508","s":"FAIL","why">">">WH not strapped.","fix":"Two straps, top 1/3 + bottom 1/3.","rep":"IPC 508.2 requires seismic restraint."},
{"id":61,"t":"Expansion Tank","c":"IPC 608","s":"CHECK","why">Closed system no tank.","fix":"Install thermal expansion tank.","rep":"IPC 608.3 prevents pressure damage."},
{"id":62,"t":"Gas Line Size","c":"IFGC 402","s":"CHECK","why">Undersized to BTU.","fix":"Size per IFGC Table 402.4.","rep":"IFGC 402 requires adequate pipe size."},
{"id":63,"t":"Gas Test Cap","c":"IFGC 406","s":"FAIL","why">">">Open tee no cap.","fix":"Cap all unused openings.","rep":"IFGC 406 requires capped openings."},
{"id":64,"t":"Condenser Electrical","c":"NEC 440","s":"FAIL","why">No disconnect at unit.","fix":"Weatherproof disconnect within sight.","rep":"NEC 440.14 requires disconnect."},
{"id":65,"t":"Condenser Level","c":"MFG","s":"CHECK","why">Unit not level.","fix":"Level pad to prevent oil issues.","rep":"Mfg requires level installation."},
{"id":66,"t":"Line Set Insulation","c":"IMC 1108","s":"FAIL","why">Suction line bare.","fix":"3/8in wall insulation minimum.","rep":"IMC 1108 requires insulation."},
{"id":67,"t":"Refrigerant Charge","c":"MFG","s":"CHECK","why">">">No subcool/superheat.","fix":"Weigh in or check per mfg.","rep":"Mfg requires proper charge."},
{"id":68,"t":"Airflow ESP","c":"MFG","s":"CHECK","why">">">ESP >0.5in.","fix":"Reduce static: bigger return.","rep":"High ESP kills equipment life."},
{"id":69,"t":"Blower Door Test","c":"IECC R402","s":"CHECK","why">No test on new home.","fix">">">Test to <5 ACH50.","rep">">IECC R402.4.1.2 requires test."},
{"id":70,"t":"Envelope Leakage","c":"IECC R402","s":"CHECK","why">>5 ACH50.","fix">">">Seal top plates, cans, penetrations.","rep">IECC air sealing required."},
{"id":71,"t":"Attic Hatch Insulated","c":"IECC R402","s":"FAIL","why">">">Uninsulated scuttle.","fix">R-38 insulated hatch.","rep">IECC R402.2.4 requires insulation."},
{"id":72,"t":"Ducts in Attic","c":"IECC C403","s":"CHECK","why">Ducts in vented attic.","fix">">">Move to conditioned or seal + insulate.","rep">">">IECC limits attic ducts."},
{"id":73,"t":"Building Envelope","c":"IECC R402","s":"CHECK","why">Missing air barrier.","fix">Seal plates, rim, cans.","rep">">IECC R402.4 air barrier."},
{"id":74,"t":"Windows U-Value","c":"IECC R402","s":"CHECK","why">">High U in hot climate.","fix">U-0.40 max or better.","rep">IECC Table R402.1.2."},
{"id":75,"t":"Rooftop Unit Access","c":"IMC 306","s":"FAIL","why">">">No roof access.","fix">">Permanent ladder or stairs.","rep">">IMC 306.5 access required."},
{"id":76,"t":"Roof Curb","c":"IMC 306","s":"CHECK","why">">">RTU flat on roof.","fix">">Install 14in curb.","rep">Mfg + code for roof penetration."},
{"id":77,"t":"Economizer","c":"IECC C403","s":"CHECK","why">>54k BTU no econ.","fix">Add air-side economizer.","rep">">">IECC C403.5 requires econ."},
{"id":78,"t":"Demand Control Vent","c":"IECC C403","s":"CHECK","why">>2500ft² no DCV.","fix">">">Add CO2 DCV.","rep">IECC C403.7.1 DCV required."},
{"id":79,"t":"Exhaust Hood Washdown","c":"IMC 507","s":"CHECK","why">No washdown on Type I.","fix">">">Install washdown system.","rep">">">IMC 507 for grease hoods."},
{"id":80,"t":"Grease Duct Exterior","c":"IMC 506","s":"FAIL","why">">">Exterior duct not rated.","fix">2hr rated shaft or 0 clearance duct.","rep">IMC 506.3.11 exterior requirement."},
{"id":81,"t":"Furnace Drainage","c":"IMC 307","s":"FAIL","why">High eff no drain.","fix">">">PVC drain with trap to plumbing.","rep">IMC 307 condensate for condensing."},
{"id":82,"t":"Neutralizer","c":"MFG","s":"CHECK","why">">">Acid condensate to cast iron.","fix">">">Install neutralizer.","rep">">">Protect plumbing per mfg."},
{"id":83,"t":"Heat Pump Defrost","c":"MFG","s":"CHECK","why">">">Ice buildup no defrost.","fix">Check defrost board/sensor.","rep">Mfg defrost required."},
{"id":84,"t":"Heat Pump Clearance","c":"MFG","s":"CHECK","why">">"><12in from wall.","fix">">12in service + 24in fan side.","rep">Mfg clearance for airflow."},
{"id":85,"t":"Mini-Split Drain","c":"MFG","s":"FAIL","why">No drain line.","fix">Install sloped drain with trap.","rep">Mfg requires condensate removal."},
{"id":86,"t":"Mini-Split Line Cover","c":"MFG","s":"CHECK","why">">">Exposed lineset.","fix">">">Install line hide cover.","rep">Protect from UV/damage."},
{"id":87,"t":"Boiler Relief Valve","c":"IMC 1006","s":"FAIL","why">">">No relief valve.","fix">ASME rated relief to floor.","rep">">IMC 1006.6 requires relief."},
{"id":88,"t":"Boiler Expansion","c":"IMC 1007","s":"FAIL","why">">">No expansion tank.","fix">">Install ASME tank.","rep">IMC 1007 requires expansion."},
{"id":89,"t":"Hydronic Air Separator","c":"IMC","s":"CHECK","why">">">No air removal.","fix">">">Install air separator.","rep">">">Prevents air lock."},
{"id":90,"t":"Hydronic Pump Isolation","c":"IMC","s":"CHECK","why">">">No flanges/valves.","fix">">Add isolation valves.","rep">">">Serviceability per good practice."},
{"id":91,"t":"Chimney Cap","c":"IMC 802","s":"CHECK","why">">">No cap/rain.","fix">Install listed cap.","rep">">">Prevent water entry."},
{"id":92,"t":"Chimney Liner Size","c":"IMC 802","s":"FAIL","why">">">Oversized liner.","fix">">">Size to appliance.","rep">">IMC 802.26 sizing."},
{"id":93,"t":"B-Vent Firestop","c":"IMC 802","s":"FAIL","why">">">No firestop at ceiling.","fix">Install listed firestop.","rep">IMC 802 requires firestop."},
{"id":94,"t":"Exhaust Fan Noise","c":"IMC 403","s":"CHECK","why">">>1.0 sone.","fix">">">Use <1.0 sone fan.","rep">">">IMC quiet requirement."},
{"id":95,"t": "Duct Design", "c": "IMC 603", "s": "CHECK", "why": "No design, flex all over.", "fix": "Size per Manual D. Limit flex.", "rep": "IMC 603 requires proper design."},
{"id":96, "t": "Manual J Load", "c": "IMC 601", "s": "CHECK", "why": "No load calc.", "fix": "Perform ACCA Manual J.", "rep": "IMC 601 requires load calc."},
{"id":97, "t": "Manual S Equipment", "c": "IMC 601", "s": "CHECK", "why": "Oversized equipment.", "fix": "Size per Manual S.", "rep": "IMC 601 equipment sizing."},
{"id":98, "t": "Manual D Ducts", "c": "IMC 603", "s": "CHECK", "why": "No duct design.", "fix": "Perform Manual D.", "rep": "IMC 603 duct sizing."},
{"id":99, "t": "Refrigerant Leak", "c": "IMC 1105", "s": "FAIL", "why": "Leak present.", "fix": "Repair + leak test.", "rep": "IMC 1105 prohibits leaks."},
{"id":100, "t": "Final Inspection Label", "c": "IMC 106", "s": "CHECK", "why": "No permit/inspection.", "fix": "Call for inspection. Post label.", "rep": "IMC 106 requires permit."}
]
