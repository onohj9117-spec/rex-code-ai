[{"id":1,"t":"Dryer Duct Material","c":"IMC 2021 504.6","s":"FAIL","why":"Foil, plastic, or screws inside.","fix":"Rigid metal only. UL181B-FX tape. No screws.","rep":"IMC 2021 504.6: Rigid metal duct, smooth interior."},{"id":2,"t":"Dryer Max Length","c":"IMC 2021 504.6.4.1","s":"CHECK","why":"Over 35ft before deductions.","fix":"-2.5ft per 45°, -5ft per 90°. Max 35ft.","rep":"IMC 2021 Table 504.6.4.1: Deduct for elbows."},{"id":3,"t":"Dryer Termination Screen","c":"IMC 2021 504.6.3","s":"FAIL","why":"Screen installed at cap.","fix":"Remove screen. Use backdraft damper.","rep":"IMC 2021 504.6.3: Screens prohibited."},{"id":4,"t":"Dryer Transition Duct","c":"IMC 2021 504.6.2","s":"CHECK","why":"Over 8ft or not listed.","fix":"UL 2158A, 8ft max, no concealment.","rep":"IMC 2021 504.6.2: Listed transition duct 8ft max."},{"id":5,"t":"Bath Fan Termination","c":"IMC 2021 504.4","s":"FAIL","why":"Ends in attic, soffit, or crawl.","fix":"Terminate outside with wall/roof cap.","rep":"IMC 2021 504.4: Exhaust to outdoors."},{"id":6,"t":"Bath Fan Backdraft Damper","c":"IMC 2021 504.4","s":"CHECK","why":"No damper installed.","fix":"Install listed backdraft damper.","rep":"IMC 2021 504.4: Damper required."},{"id":7,"t":"Bath Fan CFM","c":"IMC 2021 Table 403.3.1.1","s":"CHECK","why":"Under 50 CFM intermittent.","fix":"50 CFM min intermittent, 20 CFM cont.","rep":"IMC 2021 Table 403.3.1.1: Min ventilation."},{"id":8,"t":"Bath Fan Duct Size","c":"IMC 2021 504.6","s":"CHECK","why":"4in duct on 150+ CFM.","fix":"Use 6in for 150+ CFM.","rep":"Undersized duct causes back pressure."},{"id":9,"t":"Kitchen Hood MUA","c":"IMC 2021 507.2","s":"FAIL","why":"Hood >400 CFM no MUA.","fix":"Add interlocked MUA or <400 CFM hood.","rep":"IMC 2021 507.2: MUA required >400 CFM."},{"id":10,"t":"Hood Duct Material","c":"IMC 2021 506.3.1","s":"FAIL","why":"Flex or B-vent on grease hood.","fix":"16ga black steel, welded.","rep":"IMC 2021 506.3.1: Steel grease duct."},{"id":11,"t":"Hood Combustible Clearance","c":"IMC 2021 506.3.6","s":"FAIL","why":"<18in to wood.","fix":"18in clearance or UL 1978 0-clearance.","rep":"IMC 2021 506.3.6: 18in to combustibles."},{"id":12,"t":"Hood Access Panel","c":"IMC 2021 506.3.10","s":"CHECK","why":"No access within 20ft.","fix":"Install access panel max 20ft apart.","rep":"IMC 2021 506.3.10: Access for cleaning."},{"id":13,"t":"Water Heater Vent Type","c":"IMC 2021 802","s":"FAIL","why":"Single wall on B-vent appliance.","fix":"Use Type B vent or listed single wall.","rep":"IMC 2021 802: Listed vent per listing."},{"id":14,"t":"Vent Combustible Clearance","c":"IMC 2021 Table 802.6","s":"FAIL","why":"Single wall <6in to wood.","fix":"6in clearance, or 1in for B-vent.","rep":"IMC 2021 Table 802.6.1: 6in single wall."},{"id":15,"t":"Vent Slope","c":"IMC 2021 802.10","s":"CHECK","why":"Vent slopes down.","fix":"1/4in per ft rise to appliance.","rep":"IMC 2021 802.10: Positive slope."},{"id":16,"t":"Vent Termination Height","c":"IMC 2021 802.7","s":"CHECK","why":"<2ft above roof.","fix":"2ft above roof within 10ft.","rep":"IMC 2021 802.7.1: 2ft above roof."},{"id":17,"t":"Combustion Air Closet","c":"IMC 2021 701.4","s":"FAIL","why":"Closet with no openings.","fix":"2 openings, 1in² per 1000 BTU, high+low.","rep":"IMC 2021 701.4.1: Two permanent openings."},{"id":18,"t":"Direct Vent Appliance","c":"IMC 2021 701.2","s":"PASS","why":"Sealed combustion.","fix":"None. Uses outdoor air.","rep":"IMC 2021 701.2: Direct vent exempt."},{"id":19,"t":"Condensate Secondary Pan","c":"IMC 2021 307.2.3","s":"FAIL","why":"No pan under attic AHU.","fix":"3in deep pan, 1.5in larger than unit.","rep":"IMC 2021 307.2.3: Secondary pan required."},{"id":20,"t":"Pan Drain Location","c":"IMC 2021 307.2.3","s":"FAIL","why":"Drains to hidden spot.","fix":"Drain to conspicuous exterior location.","rep":"IMC 2021 307.2.3: Conspicuous termination."},{"id":21,"t":"Condensate Trap","c":"IMC 2021 307.2.2","s":"FAIL","why":"No P-trap on negative coil.","fix":"Install trap per mfg depth.","rep":"IMC 2021 307.2.2: Trap required."},{"id":22,"t":"Condensate Slope","c":"IMC 2021 307.2","s":"CHECK","why":"Flat drain line.","fix":"1/8in per ft minimum slope.","rep":"IMC 2021 307.2: Gravity flow required."},{"id":23,"t":"Aux Drain Float Switch","c":"IMC 2021 307.2.3","s":"FAIL","why":"No shutoff on secondary.","fix":"Install float switch to kill unit.","rep":"IMC 2021 307.2.3: Shutoff required."},{"id":24,"t":"Duct Sealing Material","c":"IMC 2021 603.9","s":"FAIL","why":"Cloth duct tape used.","fix":"UL181B-FX tape or UL181 mastic.","rep":"IMC 2021 603.9: No cloth tape."},{"id":25,"t":"Flex Duct Sag","c":"IMC 2021 603.4","s":"CHECK","why":"Sag >1/2in per ft.","fix":"Support every 4ft, pull tight.","rep":"IMC 2021 603.4: Max 1/2in sag per ft."},{"id":26,"t":"Flex Duct Bends","c":"IMC 2021 603.4","s":"CHECK","why":"Tight 90° bends.","fix":"Use elbows, limit bends.","rep":"IMC 2021 603.4: No sharp bends."},{"id":27,"t":"Return Air Cavity","c":"IMC 2021 601.3","s":"FAIL","why":"Stud/joist panned return.","fix":"Install metal duct or ductboard.","rep":"IMC 2021 601.3: No building cavities."},{"id":28,"t":"Filter Access","c":"IMC 2021 605.1","s":"CHECK","why":"No access to filter.","fix":"Install access door at filter.","rep":"IMC 2021 605.1: Filter access required."},{"id":29,"t":"Equipment Service Clearance","c":"IMC 2021 306.5","s":"CHECK","why":"<30in working space.","fix":"30in deep x 30in wide clear.","rep":"IMC 2021 306.5: 30in service space."},{"id":30,"t":"Attic Access Platform","c":"IMC 2021 306.3","s":"FAIL","why":"No platform to unit.","fix":"30in x 30in platform + walkway.","rep":"IMC 2021 306.3: Access platform required."},{"id":31,"t":"Attic Light + Outlet","c":"IMC 2021 306.5","s":"FAIL","why":"No light or receptacle.","fix":"Switched light + 120V within 25ft.","rep":"IMC 2021 306.5: Light + outlet required."},{"id":32,"t":"Gas Shutoff Access","c":"IFGC 2021 409.1","s":"FAIL","why":"Shutoff behind unit.","fix":"Accessible within 6ft.","rep":"IFGC 2021 409.1: Accessible shutoff."},{"id":33,"t":"Gas Sediment Trap","c":"IFGC 2021 408.4","s":"FAIL","why":"No drip leg.","fix":"Install sediment trap before appliance.","rep":"IFGC 2021 408.4: Sediment trap required."},{"id":34,"t":"Gas Pipe Support","c":"IFGC 2021 415","s":"CHECK","why":">6ft between supports.","fix":"Support every 6ft max.","rep":"IFGC 2021 415: Support spacing."},{"id":35,"t":"Electrical Disconnect","c":"IMC 2021 306.4","s":"FAIL","why":">50ft or not in sight.","fix":"Disconnect within sight, <50ft.","rep":"IMC 2021 306.4: Disconnect required."},{"id":36,"t":"Condenser Clearance","c":"IMC 2021 306.5","s":"CHECK","why":"<12in from wall.","fix":"12in minimum service space.","rep":"IMC 2021 306.5: Service clearance."},{"id":37,"t":"Condenser Pad","c":"IMC 2021 306.5","s":"CHECK","why":"Unit on dirt.","fix":"3in minimum pad or stand.","rep":"Mfg + code: Elevate unit."},{"id":38,"t":"Refrigerant Line Protection","c":"IMC 2021 1108","s":"CHECK","why":"Exposed lineset.","fix":"Add line set cover/chase.","rep":"IMC 2021 1108: Protect from damage."},{"id":39,"t":"Line Set Insulation","c":"IMC 2021 1108","s":"FAIL","why":"Suction line bare.","fix":"3/8in wall insulation min.","rep":"IMC 2021 1108: Insulation required."},{"id":40,"t":"Exhaust to Garage","c":"IMC 2021 501.2","s":"FAIL","why":"Bath/dryer vents to garage.","fix":"Reroute to exterior.","rep":"IMC 2021 501.2: No garage termination."},{"id":41,"t":"Exhaust Separation","c":"IMC 2021 501.3","s":"CHECK","why":"<3ft from window.","fix":"3ft from openings, 10ft from intake.","rep":"IMC 2021 501.3: Separation distances."},{"id":42,"t":"CO Alarm","c":"IRC 2021 R315.1","s":"FAIL","why":"Fuel appliance no CO.","fix":"Install CO alarm per IRC.","rep":"IRC 2021 R315.1: CO alarm required."},{"id":43,"t":"Duct Support","c":"IMC 2021 603.10","s":"CHECK","why":">4ft between hangers.","fix":"Support metal every 4ft, flex 3ft.","rep":"IMC 2021 603.10: Support spacing."},{"id":44,"t":"Fire Damper","c":"IMC 2021 607","s":"FAIL","why":"No damper in rated wall.","fix":"Install listed fire damper.","rep":"IMC 2021 607: Damper in rated assembly."},{"id":45,"t":"Fresh Air Ventilation","c":"IMC 2021 403.3","s":"CHECK","why":"No OA on new home.","fix":"Add ERV/HRV or OA damper.","rep":"IMC 2021 403.3: Ventilation air required."},{"id":46,"t":"Chimney Liner Size","c":"IMC 2021 802.26","s":"FAIL","why":"Oversized flue.","fix":"Line to appliance size.","rep":"IMC 2021 802.26: Proper flue size."},{"id":47,"t":"Chimney Firestop","c":"IMC 2021 802","s":"FAIL","why":"No firestop at ceiling.","fix":"Install listed firestop.","rep":"IMC 2021 802: Firestop required."},{"id":48,"t":"Water Heater T&P","c":"IPC 2021 504.6","s":"FAIL","why":"No T&P drain line.","fix":"Full size to 6in of floor.","rep":"IPC 2021 504.6: T&P discharge."},{"id":49,"t":"Water Heater Pan","c":"IPC 2021 504.7","s":"FAIL","why":"No pan in attic.","fix":"Add pan with drain.","rep":"IPC 2021 504.7: Pan in sensitive areas."},{"id":50,"t":"Seismic Strapping WH","c":"IPC 2021 508.2","s":"FAIL","why":"WH not strapped.","fix":"2 straps, top 1/3 + bottom 1/3.","rep":"IPC 2021 508.2: Seismic restraint."},{"id":51,"t":"Expansion Tank","c":"IPC 2021 608.3","s":"CHECK","why":"Closed system no tank.","fix":"Install thermal expansion tank.","rep":"IPC 2021 608.3: Expansion tank."},{"id":52,"t":"Gas Line Sizing","c":"IFGC 2021 402.4","s":"CHECK","why":"Undersized for BTU.","fix":"Size per Table 402.4.","rep":"IFGC 2021 402.4: Adequate pipe size."},{"id":53,"t":"Refrigerant Leak","c":"IMC 2021 1105","s":"FAIL","why":"Leak present.","fix":"Repair and leak test.","rep":"IMC 2021 1105: No leaks permitted."},{"id":54,"t":"Permit + Inspection","c":"IMC 2021 106.4","s":"CHECK","why":"No permit.","fix":"Call for inspection, post label.","rep":"IMC 2021 106.4: Permit required."},{"id":55,"t":"Bath Fan Timer","c":"IMC 2021 403","s":"CHECK","why":"No auto-off.","fix":"Add timer or humidity switch.","rep":"IMC 2021 403: Adequate runtime."},{"id":56,"t":"Hood Velocity","c":"IMC 2021 507.4","s":"CHECK","why":"<100 FPM at face.","fix":"Adjust fan or hood size.","rep":"IMC 2021 507.4: 100-200 FPM."},{"id":57,"t":"Grease Duct Slope","c":"IMC 2021 506.3.7","s":"FAIL","why":"Flat grease duct.","fix":"1/4in per ft to hood.","rep":"IMC 2021 506.3.7: Slope to drain."},{"id":58,"t":"Fire Suppression Hood","c":"IMC 2021 507.3","s":"FAIL","why":"Commercial hood no Ansul.","fix":"Install listed suppression.","rep":"IMC 2021 507.3: Suppression required."},{"id":59,"t":"Makeup Air Interlock","c":"IMC 2021 507.2","s":"FAIL","why":"MUA not wired to hood.","fix":"Interlock MUA with hood.","rep":"IMC 2021 507.2: Simultaneous operation."},{"id":60,"t":"Furnace Flue Liner","c":"IMC 2021 802","s":"FAIL","why":"Oversized masonry flue.","fix":"Line to appliance size.","rep":"IMC 2021 802.26: Proper size."},
{"id":61,"t":"Duct R-Value Attic","c":"IECC 2024 C403.11.3","s":"CHECK","why":"<R-8 in attic.","fix":"Wrap to R-8 min. Seal first.","rep":"IECC 2024 C403.11.3: R-8 attic ducts."},{"id":62,"t":"Duct R-Value Crawl","c":"IECC 2024 C403.11.3","s":"CHECK","why":"<R-6 in crawl.","fix":"Wrap to R-6 min.","rep":"IECC 2024 C403.11.3: R-6 crawl ducts."},{"id":63,"t":"Duct Leakage Test","c":"IECC 2024 C403.12.3","s":"CHECK","why":"No test on new.","fix":"Test to ≤4 CFM25 per 100ft².","rep":"IECC 2024 C403.12.3: Leakage test required."},{"id":64,"t":"Attic Insulation R-Value","c":"IECC 2024 R402.1.2","s":"CHECK","why":"<R-49 in Zone 3.","fix":"Add to R-49.","rep":"IECC 2024 R402.1.2: Attic R-49 min."},{"id":65,"t":"Wall Insulation","c":"IECC 2024 R402.1.2","s":"CHECK","why":"2x4 wall R-13 only.","fix":"R-20 or R-13+5ci.","rep":"IECC 2024 R402.1.2: Wood frame R-20."},{"id":66,"t":"Window U-Factor","c":"IECC 2024 R402.1.2","s":"CHECK","why":">U-0.32.","fix":"U-0.32 or lower.","rep":"IECC 2024 R402.1.2: Max U-0.32."},{"id":67,"t":"Air Barrier Continuous","c":"IECC 2024 R402.4","s":"FAIL","why":"Top plates not sealed.","fix":"Seal all penetrations.","rep":"IECC 2024 R402.4: Continuous air barrier."},{"id":68,"t":"Blower Door Test","c":"IECC 2024 R402.4.1.2","s":"CHECK","why":"No test.","fix":"Test to ≤5 ACH50.","rep":"IECC 2024 R402.4.1.2: Test required."},{"id":69,"t":"Air Leakage Rate","c":"IECC 2024 R402.4.1.2","s":"CHECK","why":">5 ACH50.","fix":"Seal cans, plates, penetrations.","rep":"IECC 2024 R402.4.1.2: ≤5 ACH50."},{"id":70,"t":"Attic Hatch Insulation","c":"IECC 2024 R402.2.4","s":"FAIL","why":"Uninsulated scuttle.","fix":"R-38 insulated hatch.","rep":"IECC 2024 R402.2.4: Hatch insulation."},{"id":71,"t":"Ducts in Vented Attic","c":"IECC 2024 C403","s":"CHECK","why":"Ducts in vented attic.","fix":"Move to conditioned or seal/insulate.","rep":"IECC 2024: Limit attic ducts."},{"id":72,"t":"Floor Insulation","c":"IECC 2024 R402.1.2","s":"CHECK","why":"<R-30 over crawl.","fix":"R-30 min.","rep":"IECC 2024 R402.1.2: Floor R-30."},{"id":73,"t":"Slab Edge Insulation","c":"IECC 2024 R402.2.10","s":"CHECK","why":"No R-10 slab edge.","fix":"R-10 vertical insulation.","rep":"IECC 2024 R402.2.10: Slab edge R-10."},{"id":74,"t":"Exterior Door U-Factor","c":"IECC 2024 R402.1.2","s":"CHECK","why":">U-0.35.","fix":"U-0.35 or lower.","rep":"IECC 2024 R402.1.2: Door U-0.35 max."},{"id":75,"t":"Skylight U-Factor","c":"IECC 2024 R402.1.2","s":"CHECK","why":">U-0.55.","fix":"U-0.55 or lower.","rep":"IECC 2024 R402.1.2: Skylight U-0.55."},{"id":76,"t":"Pipe Insulation Hot Water","c":"IECC 2024 R403.5.3","s":"CHECK","why":"Bare hot water pipes.","fix":"R-3 insulation min.","rep":"IECC 2024 R403.5.3: Pipe insulation."},{"id":77,"t":"Water Heater EF","c":"IECC 2024 R403.5","s":"CHECK","why":"<0.82 EF.","fix":"0.82 EF minimum.","rep":"IECC 2024 R403.5: 0.82 EF min."},{"id":78,"t":"Recirc Pump Control","c":"IECC 2024 R403.5.1","s":"CHECK","why":"No demand control.","fix":"Add demand recirc.","rep":"IECC 2024 R403.5.1: Demand control."},{"id":79,"t":"Thermostat Programmable","c":"IECC 2024 R403.1","s":"PASS","why":"Programmable installed.","fix":"N/A","rep":"IECC 2024 R403.1: Programmable stat."},{"id":80,"t":"Duct Sealing","c":"IECC 2024 R403.3.2","s":"CHECK","why":"Leaky seams.","fix":"Mastic all seams, UL181 tape.","rep":"IECC 2024 R403.3.2: Seal ducts."},{"id":81,"t":"Envelope Air Sealing","c":"IECC 2024 R402.4","s":"CHECK","why":"Can lights not ICAT.","fix":"Use ICAT cans, seal plates.","rep":"IECC 2024 R402.4: Air seal."},{"id":82,"t":"Rim Joist Insulation","c":"IECC 2024 R402.1.2","s":"CHECK","why":"Uninsulated rim.","fix":"R-20 or spray foam.","rep":"IECC 2024 R402.1.2: Rim insulation."},{"id":83,"t":"Garage Separation","c":"IRC 2021 R302.6","s":"CHECK","why":"<5/8in drywall.","fix":"5/8in Type X.","rep":"IRC 2021 R302.6: Garage separation."},{"id":84,"t":"Garage Door Self-Close","c":"IRC 2021 R302.5.1","s":"CHECK","why":"No self-closer.","fix":"Install self-closing door.","rep":"IRC 2021 R302.5.1: Self-close required."},{"id":85,"t":"Egress Window","c":"IRC 2021 R310.1","s":"CHECK","why":"Sill >44in.","fix":"Sill 44in max.","rep":"IRC 2021 R310.1: Egress sill height."},{"id":86,"t":"Smoke Alarms","c":"IRC 2021 R314.3","s":"CHECK","why":"No bedroom smoke.","fix":"Smoke in each bedroom.","rep":"IRC 2021 R314.3: Smoke alarm."},{"id":87,"t":"Stair Rise","c":"IRC 2021 R311.7.5","s":"CHECK","why":">7.75in rise.","fix":"7.75in max rise.","rep":"IRC 2021 R311.7.5: Max rise."},{"id":88,"t":"Handrail","c":"IRC 2021 R311.7.8","s":"CHECK","why":"No graspable rail.","fix":"Install Type I or II.","rep":"IRC 2021 R311.7.8: Handrail required."},{"id":89,"t":"Guardrail Height","c":"IRC 2021 R312.1.1","s":"CHECK","why":"<36in height.","fix":"36in min.","rep":"IRC 2021 R312.1.1: 36in min."},{"id":90,"t":"Baluster Spacing","c":"IRC 2021 R312.1.3","s":"CHECK","why":">4in gap.","fix":"4in sphere rule.","rep":"IRC 2021 R312.1.3: 4in max spacing."},
{"id":91,"t":"Manual J Load Calc","c":"IMC 2021 601.2","s":"CHECK","why":"No load calc.","fix":"ACCA Manual J.","rep":"IMC 2021 601.2: Load calc required."},{"id":92,"t":"Manual S Equipment","c":"IMC 2021 601.2","s":"CHECK","why":"Oversized unit.","fix":"Size per Manual S.","rep":"IMC 2021 601.2: Equipment sizing."},{"id":93,"t":"Manual D Duct Design","c":"IMC 2021 603","s":"CHECK","why":"No duct design.","fix":"ACCA Manual D.","rep":"IMC 2021 603: Duct design required."},{"id":94,"t":"ESP Static Pressure","c":"MFG","s":"CHECK","why":">0.5in ESP.","fix":"Bigger return, reduce static.","rep":"High ESP kills equipment."},{"id":95,"t":"Filter Velocity","c":"IMC 2021 605","s":"CHECK","why":">500 FPM.","fix":"Increase filter area.","rep":"Keep face velocity <500 FPM."},{"id":96,"t":"Condenser Level","c":"MFG","s":"CHECK","why":"Unit not level.","fix":"Level pad.","rep":"Mfg: Level installation."},{"id":97,"t":"Refrigerant Charge","c":"MFG","s":"CHECK","why":"No subcool/superheat.","fix":"Check per mfg.","rep":"Mfg: Proper charge required."},{"id":98,"t":"Exhaust Fan Noise","c":"IMC 2021 403","s":"CHECK","why":">1.0 sone.","fix":"Use <1.0 sone fan.","rep":"IMC 2021: Quiet requirement."},{"id":99,"t":"Heat Pump Defrost","c":"MFG","s":"CHECK","why":"Ice buildup.","fix":"Check defrost sensor/board.","rep":"Mfg: Defrost required."},{"id":100,"t":"Mini-Split Drain","c":"MFG","s":"FAIL","why":"No drain line.","fix":"Sloped drain with trap.","rep":"Mfg: Condensate removal."}]
